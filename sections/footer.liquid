{% if settings.enable_rtl %}
<link rel="stylesheet" href="{{ 'footer-rtl-css.css' | asset_url }}" media="print" onload="this.media='all'">
{% else %}
<link rel="stylesheet" href="{{ 'footer-css.css' | asset_url }}" media="print" onload="this.media='all'">
{% endif %}
<section class="footer-area" {% if section.settings.footer_bg_img_enable %}style="background-image: url('{% if section.settings.footer_bg_img %}{{ section.settings.footer_bg_img | image_url: 'master' }}{% else %}https://dummyimage.com/1920x450/f7f7f7/999999{% endif %}');"{% endif %} data-section-id="{{ section.id }}">
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="footer-top-wrap">
          <ul class="footer-top-ul">
            <li class="footer-top-li logo-wrap">
              <div class="logo-info">
                {%- render 'company-logo' -%}
                <div class="info-area">
                  {% if section.settings.info_icon_class != '' %}
                  <span class="info-icon"><i class="{{ section.settings.info_icon_class }}"></i></span>
                  {% endif %}
                  {% if section.settings.info_text != '' %}
                  <div class="info-text">{{ section.settings.info_text }}</div>
                  {% endif %}
                </div>
              </div>
            </li>
            <li class="footer-top-li contact-wrap">
              <div class="contact-area">
                {% if section.settings.contact_title != '' %}
                <h4 class="title">{{ section.settings.contact_title }}</h4>
                {% endif %}
                <div class="contact-block">
                  <div class="contact-item">
                    {% if section.settings.contact_1_icon_class != '' %}
                    <span class="contact-icon"><i class="{{ section.settings.contact_1_icon_class }}"></i></span>
                    {% endif %}
                    {% if section.settings.contact_1_text != '' %}
                    <div class="contact-text">{{ section.settings.contact_1_text }}</div>
                    {% endif %}
                  </div>
                  <div class="contact-item">
                    {% if section.settings.contact_2_icon_class != '' %}
                    <span class="contact-icon"><i class="{{ section.settings.contact_2_icon_class }}"></i></span>
                    {% endif %}
                    {% if section.settings.contact_2_text != '' %}
                    <div class="contact-text">{{ section.settings.contact_2_text }}</div>
                    {% endif %}
                  </div>  
                </div>
              </div>
            </li>
            <li class="footer-top-li news-content">
              <div class="content-block">
                {% if section.settings.newsletter_title != '' %}
                <h4 class="title">{{ section.settings.newsletter_title }}</h4>
                {% endif %}
                {% if section.settings.newsletter_desc != '' %}
                <p class="desc">{{ section.settings.newsletter_desc }}</p>
                {% endif %}
              </div>
            </li>
            <li class="footer-top-li newsletter-wrap">
              {%- render 'newsletter' -%}
              <div class="agree-btn">
                <div class="check-input">
                  <label class="box-area">
                    <span class="agree-text">{{ section.settings.contact_agree_text }}</span>
                    <input type="checkbox" class="cust-checkbox">
                    <span class="cust-check"></span>
                  </label>
                </div>
              </div>
            </li>
          </ul>
        </div>
        <div class="footer-list-wrap">
          <ul class="footer-list">
            {% for block in section.blocks %}
            {%- liquid assign row_width = row_width | plus: block.settings.container_width -%}
            {%- case block.type -%}
            {%- when 'footer_menu' -%}
            <li class="ftlink-li link-list width-{{ block.id }}">
              {% assign footer_menu = block.settings.footer_menu_handle %}
              {%- if block.settings.show_nav_title -%}
              <h4 class="ft-title md-d-none">{{ linklists[footer_menu].title }}</h4>
              <a data-bs-toggle="collapse" href="#collapse-{{ linklists[footer_menu].title | handleize }}" class="ft-title"><span>{{ linklists[footer_menu].title }}</span><i class="ri-add-fill"></i></a>
              {%- endif -%}
              <ul class="{% if block.settings.show_nav_title %}collapse {% endif %} footer-sublist link" id="{%- if block.settings.show_nav_title -%}collapse-{{ linklists[footer_menu].title | handleize }}{%- endif -%}">
                {% assign footer_menu = block.settings.footer_menu_handle %}
                {% for link in linklists[footer_menu].links %}
                {% if linklists[footer_menu].links != '' %}
                <li class="ftsublink-li">
                  <a href="{{ link.url }}" class="ft-sublink">{{ link.title }}</a>
                </li>
                {% endif %}
                {% endfor %}
              </ul>
              {%- style -%}
              .footer-list-wrap ul.footer-list li.width-{{ block.id }}{
                width: calc({{ block.settings.container_width }}% - 30px);
              }
              @media (max-width: 1199px) {
                .footer-list-wrap ul.footer-list li.width-{{ block.id }}{
                  width: calc(33.33% - 30px);
                }
              }
              @media (max-width: 767px) {
                .footer-list-wrap ul.footer-list li.width-{{ block.id }}{
                  width: calc(33.33% - 12px);
                }
              }
              @media (max-width: 479px) {
                .footer-list-wrap ul.footer-list li.width-{{ block.id }}{
                  width: calc(100% - 12px);
                }
              }
              {%- endstyle -%}
            </li>

            {%- when 'instagram' -%}
              <li class="ftlink-li instagram-wrap width-{{ block.id }}">

                {% if block.settings.instagram_title != '' %}
                <h4 class="ft-title md-d-none">{{ block.settings.instagram_title }}</h4>
                {% endif %}

                <div class="insta-block">
                  <ul class="insta-ul">
                    <li class="insta-li">
                      <div class="insta-main">
                        <a href="{{ block.settings.insta_1_url }}" class="insta-url">
                          <span class="insta-image">
                            {%- if block.settings.insta_1_image -%}
                            {{ block.settings.insta_1_image | image_url: width: 512 | image_tag:
                              loading: 'lazy',
                              width: block.settings.insta_1_image.width,
                              height: block.settings.insta_1_image.height,
                              class: "img-fluid",
                              alt: block.settings.insta_1_image.alt | escape }}
                            {%- else -%}
                            {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                            {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          </span>
                          <span class="insta-icon"><i class="ri-instagram-line"></i></span>
                        </a>
                      </div>
                    </li>
                    <li class="insta-li">
                      <div class="insta-main">
                        <a href="{{ block.settings.insta_2_url }}" class="insta-url">
                          <span class="insta-image">
                            {%- if block.settings.insta_2_image -%}
                            {{ block.settings.insta_2_image | image_url: width: 512 | image_tag:
                              loading: 'lazy',
                              width: block.settings.insta_2_image.width,
                              height: block.settings.insta_2_image.height,
                              class: "img-fluid",
                              alt: block.settings.insta_2_image.alt | escape }}
                            {%- else -%}
                            {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                            {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          </span>
                          <span class="insta-icon"><i class="ri-instagram-line"></i></span>
                        </a>
                      </div>
                    </li>
                    <li class="insta-li">
                      <div class="insta-main">
                        <a href="{{ block.settings.insta_3_url }}" class="insta-url">
                          <span class="insta-image">
                            {%- if block.settings.insta_3_image -%}
                            {{ block.settings.insta_3_image | image_url: width: 512 | image_tag:
                              loading: 'lazy',
                              width: block.settings.insta_3_image.width,
                              height: block.settings.insta_3_image.height,
                              class: "img-fluid",
                              alt: block.settings.insta_3_image.alt | escape }}
                            {%- else -%}
                            {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                            {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          </span>
                          <span class="insta-icon"><i class="ri-instagram-line"></i></span>
                        </a>
                      </div>
                    </li>
                    <li class="insta-li">
                      <div class="insta-main">
                        <a href="{{ block.settings.insta_4_url }}" class="insta-url">
                          <span class="insta-image">
                            {%- if block.settings.insta_4_image -%}
                            {{ block.settings.insta_4_image | image_url: width: 512 | image_tag:
                              loading: 'lazy',
                              width: block.settings.insta_4_image.width,
                              height: block.settings.insta_4_image.height,
                              class: "img-fluid",
                              alt: block.settings.insta_4_image.alt | escape }}
                            {%- else -%}
                            {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                            {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          </span>
                          <span class="insta-icon"><i class="ri-instagram-line"></i></span>
                        </a>
                      </div>
                    </li>
                  </ul>
                </div>

                {%- style -%}
                .footer-list-wrap ul.footer-list li.width-{{ block.id }}{
                  width: calc({{ block.settings.container_width }}% - 30px);
                }
                @media (max-width: 1199px) {
                  .footer-list-wrap ul.footer-list li.width-{{ block.id }}{
                    width: calc(100% - 30px);
                  }
                }
                @media (max-width: 767px) {
                  .footer-list-wrap ul.footer-list li.width-{{ block.id }}{
                    width: calc(100% - 12px);
                  }
                }
                @media (max-width: 600px) {
                  
                }
                {%- endstyle -%}
              </li>

            {%- endcase -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
