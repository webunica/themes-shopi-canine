<section class="slider-content">
  <div class="home-slider owl-carousel owl-theme" id="home-slider-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="item">
        <div class="slide-image">
          {%- if block.settings.slider_img -%}
          {{ block.settings.slider_img | image_url: width: 1920 | image_tag:
          loading: 'lazy',
          width: block.settings.slider_img.width,
          height: block.settings.slider_img.height,
          class: "img-fluid desk-img",
          alt: block.settings.slider_img.alt | escape }}
          {%- else -%}  
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg desk-img' }}
          {%- endif -%}

          {%- if block.settings.slider_mobile_img -%}  
          {{ block.settings.slider_mobile_img | image_url: width: 1024 | image_tag:
             loading: 'lazy',
             width: block.settings.slider_mobile_img.width,
             height: block.settings.slider_mobile_img.height,
             class: "img-fluid mobile-img",
             alt: block.settings.slider_mobile_img.alt | escape }} 
          {%- else -%}
          {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
          {{ placeholder | placeholder_svg_tag: 'placeholder-svg mobile-img' }}
          {%- endif -%}

          <div class="container slider-info-content">
            <div class="row">
              <div class="col">
                <div class="slider-text-info item-{{ block.id }} {% if block.settings.slider_content_position == "right" %} slider-content-right{% elsif block.settings.slider_content_position == "left" %} slider-content-left{% else %} slider-content-center{% endif %}{% if block.settings.slider_text_position == "right" %} slider-text-right{% elsif block.settings.slider_text_position == "left" %} slider-text-left{% else %} slider-text-center{% endif %}">
                  {% if block.settings.slider_title != '' %}
                  <h2 class="{% if block.settings.slider_title_effect == "e2" %}e2{% elsif block.settings.slider_title_effect == "e3" %}e3{% elsif block.settings.slider_title_effect == "e4" %}e4{% elsif block.settings.slider_title_effect == "e5" %}e5{% else %}e1{% endif %}">{{ block.settings.slider_title }}</h2>
                  {% endif %}

                  {% if block.settings.slider_subtitle != '' %}
                  <span class="slider-subtitle {% if block.settings.slider_subtitle_effect == "e2" %}e2{% elsif block.settings.slider_subtitle_effect == "e3" %}e3{% elsif block.settings.slider_subtitle_effect == "e4" %}e4{% elsif block.settings.slider_subtitle_effect == "e5" %}e5{% else %}e1{% endif %}">{{ block.settings.slider_subtitle }}</span>
                  {% endif %}

                  <div class="slider-btn-bio {% if block.settings.slider_btn_bio_effect == "e2" %}e2{% elsif block.settings.slider_btn_bio_effect == "e3" %}e3{% elsif block.settings.slider_btn_bio_effect == "e4" %}e4{% elsif block.settings.slider_btn_bio_effect == "e5" %}e5{% else %}e1{% endif %}">
                    {% if block.settings.slider_button != '' %}
                    <a href="{{ block.settings.slider_button_url }}" class="btn {% if block.settings.slider_button_style == 'btn-style1' %}btn-style{% elsif block.settings.slider_button_style == 'btn-style2' %}btn-style2{% else %}btn-style3{% endif %}">{{ block.settings.slider_button }}</a>
                    {% endif %}
                    <div class="slider-bio">
                      {% if block.settings.bio_big_title != '' or block.settings.bio_small_title != '' %}
                      <div class="bio-title">
                        {% if block.settings.bio_big_title != '' %}
                        <h4 class="big-title">{{ block.settings.bio_big_title }}</h4>
                        {% endif %}
                        {% if block.settings.bio_small_title != '' %}
                        <span class="small-title">{{ block.settings.bio_small_title }}</span>
                        {% endif %}
                      </div>
                      {% endif %}
                      <div class="slider-review">
                        <div class="testimonial-review">
                          <span class="testi-review">
                            <i class="fa fa-star{% if block.settings.pro_testi_review == '1' or block.settings.pro_testi_review == '2' or block.settings.pro_testi_review == '3' or block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                            <i class="fa fa-star{% if block.settings.pro_testi_review == '2' or block.settings.pro_testi_review == '3' or block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                            <i class="fa fa-star{% if block.settings.pro_testi_review == '3' or block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                            <i class="fa fa-star{% if block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                            <i class="fa fa-star{% if block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          {% style %}
          .slider-content .home-slider .slide-image .slider-info-content .slider-text-info.item-{{ block.id }} h2 {
            color:{{ block.settings.slider_title_color }};
          }
          .slider-content .home-slider .slide-image .slider-info-content .slider-text-info.item-{{ block.id }} span.slider-subtitle {
            color:{{ block.settings.slider_subtitle_color }};
          }
          .slider-content .home-slider .slide-image .slider-info-content .slider-text-info .slider-btn-bio .slider-bio .bio-title h4.big-title,
          .slider-content .home-slider .slide-image .slider-info-content .slider-text-info .slider-btn-bio .slider-bio .bio-title span.small-title {
            color:{{ block.settings.slider_bio_color }};
          }
          @media (max-width: 600px) {
            .slider-content .home-slider .slide-image .slider-info-content .slider-text-info.item-{{ block.id }} h2,
            .slider-content .home-slider .slide-image .slider-info-content .slider-text-info.item-{{ block.id }} span.slider-subtitle,
            .slider-content .home-slider .slide-image .slider-info-content .slider-text-info.item-{{ block.id }} .slider-btn-bio .slider-bio .bio-title h4.big-title,
            .slider-content .home-slider .slide-image .slider-info-content .slider-text-info.item-{{ block.id }} .slider-btn-bio .slider-bio .bio-title span.small-title {
              color: var(--font-color-body);
            }  
          }
          {% endstyle %}
        </div>
      </div>
      {% endfor %}
  </div>
</section>
<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var owl = $('#home-slider-{{ section.id }}');
    owl.owlCarousel({
      loop: true,
      autoHeight:true,
      items: 1,
      rewind: false,
      margin: 0,
      nav: true,
      navText: ['<i class="feather-arrow-left"></i>','<i class="feather-arrow-right"></i>'],
      dots: false,
      {%- if settings.enable_rtl -%}
      rtl: true,
      {%- endif -%}
      {% if section.settings.slider_autoplay_enable %}
      autoplay: true,
      autoplayTimeout: {{ section.settings.slider_autoplay_timeout }},
      autoplayHoverPause: true,
      autoplaySpeed: {{ section.settings.slider_autoplay_speed }},
      {% endif %}
      responsive:{
        0:{
          items: 1,
          nav: false,
          dots: true
        },
        479:{
          items: 1,
          nav: false,
          dots: true
        },
        768:{
          items: 1,
          nav: false,
          dots: true
        },
        979:{
          items: 1,
          nav: true,
          dots: false
        },
        1199: {
          items: 1,
          nav: true,
          dots: false
        }
      }
    });
    {% if section.settings.slider_autoplay_enable %}
    owl.on('changed.owl.carousel', function() {
      owl.trigger('stop.owl.autoplay');
      owl.trigger('play.owl.autoplay');
    });
    {% endif %}
  });
</script>
